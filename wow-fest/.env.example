# Скопируйте этот файл в .env и заполните значения.
# docker compose автоматически подхватит .env из этой же папки.

# Способ 1 (рекомендуется) — URL веб-приложения Google Apps Script
WOWFEST_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbw25MKHPu9lyOWQfSJNtSoK8b2tlPVma_XGloyq9LT3yqpvSOQB-lsh23-ZhJUZpQcE/exec

# Способ 2 (опционально) — ID таблицы, если используете service account + gspread
WOWFEST_SPREADSHEET_ID=

# Аналитика
WOWFEST_GA4_ID=
WOWFEST_FB_PIXEL_ID=
